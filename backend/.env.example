# =============================================================================
# 오늘 왜 떠? 백엔드 환경 변수
# .env.example을 복사해 .env로 저장한 뒤 값을 채워주세요.
# =============================================================================

# ── Supabase ──────────────────────────────────────────────────────────────────
# Supabase Dashboard → Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# ── Toss mTLS 포인트 API ─────────────────────────────────────────────────────
# 앱인토스 콘솔 → 포인트 API → 인증서 발급 후 certs/ 디렉토리에 저장
TOSS_POINTS_API_URL=https://api.toss.im/v2/mini-app/points
TOSS_MTLS_CERT_PATH=certs/client.crt
TOSS_MTLS_KEY_PATH=certs/client.key
TOSS_MTLS_CA_PATH=certs/toss-ca.crt
TOSS_APP_ID=today-hot-topic

# ── JWT ──────────────────────────────────────────────────────────────────────
# openssl rand -hex 32 으로 생성
JWT_SECRET=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200

# ── Naver 검색 API ────────────────────────────────────────────────────────────
# https://developers.naver.com 에서 발급
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# ── 포인트 정책 ───────────────────────────────────────────────────────────────
VOTE_REWARD_AMOUNT=10
AD_REWARD_AMOUNT=20
SHARE_REWARD_AMOUNT=5
DAILY_POINT_LIMIT=100

# ── 크롤러 ───────────────────────────────────────────────────────────────────
CRAWLER_INTERVAL_MINUTES=30
CRAWLER_MAX_TOPICS_PER_SOURCE=20

# ── CORS (프로덕션에서는 실제 도메인으로 변경) ─────────────────────────────────
ALLOWED_ORIGINS=["*"]
